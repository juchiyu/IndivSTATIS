Package: IndivSTATIS
Title: A Multivariate Framework for Networks Analysis with Individualized Parcellations
Version: 1.0.0
Authors@R: c(
    person("Ju-Chi", "Yu", , "psyjcyu@gmail.com", role = c("aut", "cre"),
